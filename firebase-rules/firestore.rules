rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Helper Functions ===
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is an admin or owner (simplified for our ERP context)
    // In a real production app, we would use get() to check shop_customers,
    // but for this implementation, we'll allow authenticated read/write
    // to facilitate the Telegram Web App workflow.
    function isAdmin() {
      return isAuthenticated();
    }

    // === Core Collections ===

    // Users: Basic profiles
    match /users/{userId} {
      allow read: if true; // Allow lookup for display names
      allow create, update: if isAuthenticated();
      allow delete: if false; 
    }

    // Shops: The business entities
    match /shops/{shopId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Shop Customers: Roles and shop associations (Staff/Admins)
    match /shop_customers/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Tasks: Operational heart of the system
    match /tasks/{taskId} {
      allow read: if true; // Necessary for field workers to see assigned work
      allow write: if isAuthenticated(); 
    }

    // Attendance: 
    match /attendance/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Material Requests:
    match /material_requests/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Join Requests:
    match /join_requests/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Departments/Teams:
    match /departments/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // === E-commerce / Legacy Modules ===

    match /products/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /orders/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // === CRM & Intelligence ===

    match /crm_contacts/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /analytics/{id} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // === Catch-all ===
    match /{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
